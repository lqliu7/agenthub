// ── 主菜单 ────────────────────────────────────────────────────────────────────
async function pageMain() {
  const info  = serverInfo();
  const alive = serverAlive(info);
  const metas = loadMeta();
  const now   = Date.now();

  const liveSessions  = metas.filter(s => s.alive);
  const deadSessions  = metas.filter(s => !s.alive);

  const hdr = alive
    ? A.green + '● 服务运行中' + A.R + A.gray + `  :${info.port}` + (info.pid ? `  pid ${info.pid}` : '  local') + A.R
      + (localToken() ? '' : A.yellow + '  ⚠ token 未就绪，稍等...' + A.R)
    : A.red + '✗ 服务未运行' + A.R + A.gray + '  请先执行 agenthub start' + A.R;

  const items = [];

  // 活跃会话
  if (liveSessions.length) {
    liveSessions.forEach(s => {
      const a = age(now - (s.lastActiveAt || s.createdAt));
      const ok = sockAlive(s.sessionId);
      items.push({
        label: A.green + '● ' + A.b + s.name + A.R + A.gray + '  ' + agentName(s.agent) + '  ' + cwd(s.workingDir) + A.R
             + (ok ? '' : A.red + '  [无socket]' + A.R),
        hint: a + ' ago',
        _type: 'session', _data: s,
      });
    });
  }

  // 已结束会话（灰色，收起）
  if (deadSessions.length) {
    if (liveSessions.length) items.push({ _sep: true });
    deadSessions.forEach(s => {
      const a = age(now - (s.lastActiveAt || s.createdAt));
      items.push({
        label: A.gray + '○ ' + s.name + '  ' + a + ' ago' + A.R,
        _type: 'dead', _data: s,
      });
    });
  }

  items.push({ _sep: true });
  if (alive) {
    items.push({ label: A.cyan + '＋  新建 Claude Code 对话' + A.R, _type: 'new', _agent: 'claude' });
    items.push({ label: A.cyan + '＋  新建 Codex 对话' + A.R, _type: 'new', _agent: 'codex' });
  }
  items.push({ label: A.blue + '⏎  恢复 Claude Code 历史' + A.R, hint: '从 ~/.claude 加载历史', _type: 'history', _agent: 'claude' });
  items.push({ label: A.blue + '⏎  恢复 Codex 历史' + A.R, hint: '从 ~/.codex/sessions 加载历史', _type: 'history', _agent: 'codex' });
  items.push({ label: A.gray + '↻  刷新' + A.R, _type: 'refresh' });
  items.push({ label: A.gray + '✕  退出' + A.R, _type: 'quit' });

  const idx = await menu('对话列表', items, { hdr, banner: true });
  if (idx === null) return pageMain();

  const item = items[idx];
  if (!item || item._sep) return pageMain();

  switch (item._type) {
    case 'session': return pageSession(item._data);
    case 'dead':    return pageDeadSession(item._data);
    case 'new':     return pageNew(info, item._agent);
    case 'history': return pageHistory(info, item._agent);
    case 'refresh': return pageMain();
    case 'quit':    wr(A.clear + A.show); process.exit(0);
  }
}

// ── 活跃会话操作 ──────────────────────────────────────────────────────────────
async function pageSession(s) {
  const sp   = sockPath(s.sessionId);
  const ok   = sockAlive(s.sessionId);
  const info = serverInfo();

  const items = [
    ok
      ? { label: A.green + '▶  接入会话' + A.R, hint: 'Ctrl+] 断开，不终止会话', _type: 'attach' }
      : { label: A.gray  + '▶  接入会话（无 socket）' + A.R, _type: 'nosock', _disabled: !ok },
    { label: A.blue  + '≡  查看日志' + A.R,                hint: 'tail -f 实时输出', _type: 'log' },
    { label: A.red   + '⏹  关闭会话' + A.R,               hint: '终止 PTY 进程',    _type: 'kill' },
    { label: A.gray  + '←  返回列表' + A.R,                                          _type: 'back' },
  ];

  const idx = await menu(
    '会话: ' + A.b + s.name + A.R,
    items,
    { hdr: A.gray + agentName(s.agent) + '  ' + cwd(s.workingDir) + '  ' + s.sessionId.slice(0,8) + A.R }
  );

  if (idx === null || items[idx]?._type === 'back') return pageMain();

  switch (items[idx]._type) {
    case 'attach':
      doAttach(sp, s.name, pageMain, s.sessionId);
      break;
    case 'nosock':
      await notice('Socket 不可用，请确认服务运行中', A.red, 1800);
      return pageMain();
    case 'log':
      await doTail(s);
      return pageMain();
    case 'kill':
      await doKillSession(s, info);
      return pageMain();
  }
}

// ── 已结束会话 ────────────────────────────────────────────────────────────────
async function pageDeadSession(s) {
  const items = [
    { label: A.blue + '≡  查看历史日志' + A.R,  _type: 'log' },
    { label: A.red  + '✕  删除会话记录' + A.R,   _type: 'delete' },
    { label: A.gray + '←  返回列表' + A.R,        _type: 'back' },
  ];
  const idx = await menu('已结束: ' + A.d + s.name + A.R, items);
  if (idx === null || items[idx]?._type === 'back') return pageMain();
  if (items[idx]._type === 'log') await doTail(s, false);
  if (items[idx]._type === 'delete') await doDeleteSession(s, info);
  return pageMain();
}

// ── Kill / Delete 会话（通过 WS 发控制消息）──────────────────────────────────
function sendControlMsg(info, msg) {
  return new Promise(resolve => {
    const tok = localToken();
    if (!tok || !info) { resolve(false); return; }
    const sock = net.createConnection(info.port, 'localhost');
    const key  = require('crypto').randomBytes(16).toString('base64');
    let upgraded = false, done = false;
    const timer = setTimeout(() => { sock.destroy(); resolve(false); }, 5000);

    sock.on('connect', () => {
      sock.write(
        `GET /ws?token=${encodeURIComponent(tok)} HTTP/1.1\r\n` +
        `Host: localhost:${info.port}\r\nUpgrade: websocket\r\nConnection: Upgrade\r\n` +
        `Sec-WebSocket-Key: ${key}\r\nSec-WebSocket-Version: 13\r\n\r\n`
      );
    });
    sock.on('data', chunk => {
      if (!upgraded) {
        const s = chunk.toString('binary');
        if (!s.includes('101')) { sock.destroy(); resolve(false); return; }
        upgraded = true;
        sock.write(wsMask(JSON.stringify(msg)));
        setTimeout(() => { if (!done) { done = true; clearTimeout(timer); sock.destroy(); resolve(true); } }, 500);
      }
    });
    sock.on('error', () => { clearTimeout(timer); resolve(false); });
  });
}

async function doKillSession(s, info) {
  wr('\n' + A.gray + '  正在关闭会话...' + A.R);
  const ok = await sendControlMsg(info, { type: 'kill', sessionId: s.sessionId });
  wr(A.up(1) + A.erase);
  if (ok) await notice('会话已关闭', A.green, 800);
  else    await notice('关闭失败，请确认服务运行中', A.red, 1500);
}

async function doDeleteSession(s, info) {
  wr('\n' + A.gray + '  正在删除会话记录...' + A.R);
  const ok = await sendControlMsg(info, { type: 'delete', sessionId: s.sessionId });
  wr(A.up(1) + A.erase);
  if (ok) await notice('已删除', A.green, 600);
  else    await notice('删除失败', A.red, 1500);
}

// ── 新建对话 ──────────────────────────────────────────────────────────────────
async function pageNew(info, agent = 'claude') {
  // 默认当前目录，和 CLI 直接运行的逻辑一致
  const workingDir = process.cwd();
  const name = path.basename(workingDir) || 'session';
  await doCreate(info, workingDir, name, '', agent);
}

// ── 恢复历史对话 ──────────────────────────────────────────────────────────────
async function pageHistory(info, agent = 'claude') {
  const projects = loadProjects(agent);

  if (!projects.length) {
    await notice(`未找到 ${agentName(agent)} 历史对话（${AGENTS[normalizeAgent(agent)].history} 为空）`, A.yellow, 2000);
    return pageMain();
  }

  // 第一级：选项目
  const items = projects.map(p => ({
    label: A.cyan + cwd(p.displayPath) + A.R + A.gray + `  ${p.sessions.length} 个对话` + A.R,
    hint:  fmtDate(p.sessions[0]?.lastModified),
    _type: 'project', _data: p,
  }));
  items.push({ _sep: true });
  items.push({ label: A.gray + '←  返回' + A.R, _type: 'back' });

  const idx = await menu('恢复历史对话  选择项目', items, {
    hdr: A.gray + '来源: ' + AGENTS[normalizeAgent(agent)].history + A.R
  });

  if (idx === null || items[idx]?._type === 'back') return pageMain();
  return pageHistorySessions(info, items[idx]._data, agent);
}

async function pageHistorySessions(info, project, agent = 'claude') {
  const sessions = project.sessions;

  const items = sessions.map(s => ({
    label: A.white + (s.lastMessage || '(无预览)') + A.R,
    sub:   `${s.messageCount} 条消息  ${fmtDate(s.lastModified)}  ${s.sessionId.slice(0,8)}`,
    hint:  s.cwd ? cwd(s.cwd) : '',
    _type: 'session', _data: s,
  }));
  items.push({ _sep: true });
  items.push({ label: A.gray + '←  返回项目列表' + A.R, _type: 'back' });

  const idx = await menu(
    '选择历史对话',
    items,
    { hdr: A.cyan + cwd(project.displayPath) + A.R }
  );

  if (idx === null || items[idx]?._type === 'back') return pageHistory(info, agent);

  const sess = items[idx]._data;
  const sessCwd = sess.cwd || '~';
  const base = path.basename(sessCwd) || 'session';
  // 直接用历史会话的目录和名称，不再询问
  await doCreate(info, sessCwd, base, sess.sessionId, agent);
}

// ── 创建会话通用逻辑 ──────────────────────────────────────────────────────────
async function doCreate(info, workingDir, name, resumeSessionId, agent = 'claude') {
  if (!info || !serverAlive(info)) {
    await notice('服务未运行，请先执行 ahub-server start', A.red, 2500);
    return pageMain();
  }

  wr('\n' + A.gray + '  正在创建会话...' + A.R);

  // token 由服务启动时生成，若不存在说明服务未运行
  let tok = localToken();
  if (!tok) {
    // 等最多 3s（服务刚启动的时间差）
    for (let i = 0; i < 6; i++) { await sl(500); tok = localToken(); if (tok) break; }
  }
  if (!tok) {
    wr(A.up(1) + A.erase + '\n');
    wr(A.red + '  ✗ 服务未运行，无法创建会话\n' + A.R);
    wr(A.gray + '  请先执行：agenthub start\n\n' + A.R);

    // 提供一键启动
    const lock = serverInfo();
    if (!lock) {
      const items = [
        { label: A.cyan + '▶  立即启动服务' + A.R, _type: 'start' },
        { label: A.gray + '←  返回菜单' + A.R,   _type: 'back' },
      ];
      const idx = await menu('服务未运行', items);
      if (idx !== null && items[idx]?._type === 'start') {
        const { execFileSync } = require('child_process');
        // 找 agenthub：同目录 → PATH
        const agenthubBin = (() => {
          const local = path.join(path.dirname(process.argv[1] || ''), 'agenthub');
          try { require('fs').accessSync(local); return local; } catch (_) {}
          return 'agenthub';
        })();
        try { execFileSync(agenthubBin, ['start'], { stdio: 'ignore' }); } catch (_) {}
        // 等服务和 token 就绪
        wr(A.show + A.gray + '\n  正在启动服务...' + A.R);
        for (let i = 0; i < 20; i++) { await sl(500); tok = localToken(); if (tok) break; }
        if (tok) { wr(A.up(1) + A.erase + A.green + '  ✓ 服务已启动\n' + A.R); await sl(400); }
        else { await notice('启动超时，请手动执行 agenthub start', A.red, 2500); return pageMain(); }
      } else {
        return pageMain();
      }
    } else {
      await sl(2500); return pageMain();
    }
  }

  try {
    const sid = await wsCreate('localhost', info.port, tok, workingDir, name, resumeSessionId, agent);
    wr(A.up(1) + A.erase + A.green + '  ✓ 会话已创建\n' + A.R);
    await sl(400);

    const sp = sockPath(sid);
    for (let i = 0; i < 50; i++) { if (IS_WIN || fs.existsSync(sp)) break; await sl(100); }
    if (!IS_WIN && !fs.existsSync(sp)) throw new Error('Socket 未建立');

    doAttach(sp, name, returnToMainAfterDetach);
  } catch (e) {
    wr(A.up(1) + A.erase + A.red + '  ✗ 创建失败: ' + e.message + '\n' + A.R);
    await sl(2500);
    return pageMain();
  }
}

// ── 日志 ──────────────────────────────────────────────────────────────────────
async function doTail(s, follow = true) {
  if (!s.logPath || !fs.existsSync(s.logPath)) {
    await notice('日志文件不存在: ' + (s.logPath || ''), A.red, 1800);
    return;
  }
  wr(A.clear + A.show);
  wr(A.cyan + '\n  ' + (follow ? 'Tailing' : 'Log') + ': ' + A.b + s.name + A.R
    + A.gray + '\n  ' + s.logPath + '\n  Ctrl+C 返回菜单\n\n' + A.R);

  return new Promise(resolve => {
    const args = follow ? ['-f', '-n', '200', s.logPath] : ['-n', '+1', s.logPath];
    const proc = spawn('tail', args, { stdio: ['ignore', 'inherit', 'inherit'] });
    const onSig = () => { proc.kill(); resolve(); };
    process.once('SIGINT', onSig);
    proc.on('close', () => { process.removeListener('SIGINT', onSig); resolve(); });
  });
}

// ── 入口 ──────────────────────────────────────────────────────────────────────
if (!process.stdin.isTTY) {
  console.error('ahub-tui 需要在交互式终端中运行');
  process.exit(1);
}

process.on('exit', () => {
  try { if (process.stdin.isTTY) process.stdin.setRawMode(false); wr(A.show); } catch (_) {}
});

// ── 命令行参数处理 ────────────────────────────────────────────────────────────
// ahub-tui --attach <name|id>  直接接入指定会话
const attachArg = (() => {
  const i = process.argv.indexOf('--attach');
  return i !== -1 ? process.argv[i + 1] : null;
})();

async function startTui() {
  if (attachArg) {
    const meta = loadMeta();
    const s = meta.find(m =>
      m.name === attachArg ||
      m.sessionId === attachArg ||
      m.sessionId.startsWith(attachArg)
    );
    if (s && s.alive && sockAlive(s.sessionId)) {
      doAttach(sockPath(s.sessionId), s.name, returnToMainAfterDetach, s.sessionId);
      return;
    }
    // 找不到或不可用，提示后进主页
    wr(A.clear);
    await notice(
      s ? `会话 "${s.name}" 不可接入（无 socket）` : `找不到会话: ${attachArg}`,
      A.yellow, 1800
    );
  }
  return pageMain();
}

startTui().catch(err => {
  wr(A.show + '\n' + A.red + '  错误: ' + err.message + A.R + '\n');
  console.error(err.stack);
  process.exit(1);
});
