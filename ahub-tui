#!/usr/bin/env node
/**
 * ahub-tui — AgentHub 交互式终端 UI
 *
 * 直接运行，无需传参：ahub-tui
 *
 * 无第三方依赖，纯 Node.js 标准库
 */

'use strict';

const net      = require('net');
const fs       = require('fs');
const path     = require('path');
const os       = require('os');
const crypto   = require('crypto');
const readline = require('readline');
const { spawn, execFileSync } = require('child_process');

// ── 路径 ──────────────────────────────────────────────────────────────────────
const IS_WIN      = process.platform === 'win32';
const HOME        = os.homedir();
const APP_DIR     = (() => {
  try { return path.dirname(fs.realpathSync(process.argv[1] || __filename)); } catch (_) { return __dirname; }
})();
const SERVER_DIR  = path.join(APP_DIR, 'server');
const AHUB_DIR     = path.join(HOME, '.agenthub');
const META_FILE   = path.join(AHUB_DIR, 'sessions.json');
const LOCK_FILE   = path.join(AHUB_DIR, 'server.lock');
const ENV_FILE    = path.join(APP_DIR, '.env');
const SOCK_DIR    = path.join(AHUB_DIR, 'sockets');
const LOCAL_TOKEN = path.join(AHUB_DIR, 'local.token');
const CLAUDE_DIR  = path.join(HOME, '.claude', 'projects');
const CODEX_HISTORY_FILE = path.join(HOME, '.codex', 'history.jsonl');
const CODEX_SESSIONS_DIR = path.join(HOME, '.codex', 'sessions');

const AGENTS = {
  claude: { id: 'claude', name: 'Claude Code', history: '~/.claude/projects/' },
  codex:  { id: 'codex',  name: 'Codex',       history: '~/.codex/sessions/' },
};
function normalizeAgent(agent) { return AGENTS[agent] ? agent : 'claude'; }
function agentName(agent) { return AGENTS[normalizeAgent(agent)].name; }

// ── ANSI ──────────────────────────────────────────────────────────────────────
const A = {
  R: '\x1b[0m', b: '\x1b[1m', d: '\x1b[2m',
  cyan: '\x1b[36m', green: '\x1b[32m', yellow: '\x1b[33m',
  red: '\x1b[31m', blue: '\x1b[34m', gray: '\x1b[90m', white: '\x1b[97m',
  BG: '\x1b[48;5;237m',   // 选中背景
  clear: '\x1bc', hide: '\x1b[?25l', show: '\x1b[?25h',
  up: (n=1) => `\x1b[${n}A`, erase: '\x1b[2K',
};

const W   = () => Math.min(process.stdout.columns || 80, 110);
const wr  = (s) => process.stdout.write(s);
const sl  = (ms) => new Promise(r => setTimeout(r, ms));
const strip = (s) => s.replace(/\x1b\[[0-9;]*m/g, '');
const padR  = (s, n) => { const d = n - strip(s).length; return d > 0 ? s + ' '.repeat(d) : s; };

function hr(c = '─', col = A.d) { return col + c.repeat(W()) + A.R; }
function ctr(s, w = W()) {
  const p = Math.max(0, Math.floor((w - strip(s).length) / 2));
  return ' '.repeat(p) + s;
}
function age(ms) {
  if (!ms || ms < 0) return '?';
  if (ms < 60000)    return Math.floor(ms / 1000) + 's';
  if (ms < 3600000)  return Math.floor(ms / 60000) + 'm';
  if (ms < 86400000) return Math.floor(ms / 3600000) + 'h';
  return Math.floor(ms / 86400000) + 'd';
}
function cwd(p) {
  if (!p) return '';
  return p.replace(/^\/paddle\//, '~/').replace(/^\/root\//, '~/').replace(/^\/home\/[^/]+\//, '~/');
}

// ── 服务信息 ──────────────────────────────────────────────────────────────────
function readEnvFile() {
  const env = {};
  try {
    for (const line of fs.readFileSync(ENV_FILE, 'utf8').split(/\r?\n/)) {
      const m = line.match(/^([A-Z_][A-Z0-9_]*)=(.*)$/);
      if (m) env[m[1]] = m[2];
    }
  } catch (_) {}
  return env;
}

function serverInfo() {
  try { return JSON.parse(fs.readFileSync(LOCK_FILE, 'utf8')); } catch (_) {}
  const env = readEnvFile();
  const port = parseInt(process.env.PORT || env.PORT || '8310', 10);
  return Number.isFinite(port) ? { pid: null, port, fallback: true } : null;
}
function serverAlive(info) {
  if (!info) return false;
  if (!info.pid) return !!localToken() && proxyOwnsPort(info.port);
  try { process.kill(info.pid, 0); return true; } catch (_) { return false; }
}
function localToken() {
  try { return fs.readFileSync(LOCAL_TOKEN, 'utf8').trim(); } catch (_) { return ''; }
}

function proxyOwnsPort(port) {
  try {
    const out = execFileSync('netstat', ['-ltnp'], { encoding: 'utf8', stdio: ['ignore', 'pipe', 'ignore'] });
    const rows = out.split(/\r?\n/).filter(line => line.includes(`:${port} `) || line.includes(`:${port}\t`));
    if (!rows.length) return false;
    return rows.some(line => {
      const pid = line.trim().split(/\s+/).pop()?.split('/')[0];
      if (!pid || !/^\d+$/.test(pid)) return false;
      try {
        const args = execFileSync('ps', ['-p', pid, '-o', 'args='], { encoding: 'utf8', stdio: ['ignore', 'pipe', 'ignore'] });
        return args.includes(path.join(SERVER_DIR, 'proxy.js'));
      } catch (_) {
        return false;
      }
    });
  } catch (_) {
    // Some systems do not expose process names through netstat; keep old local-token fallback there.
    return true;
  }
}

// ── 本地 Meta ─────────────────────────────────────────────────────────────────
function loadMeta() {
  try { return JSON.parse(fs.readFileSync(META_FILE, 'utf8')); } catch (_) { return []; }
}
function sockPath(sid) {
  return IS_WIN ? `\\\\.\\pipe\\ahub-${sid}` : path.join(SOCK_DIR, `${sid}.sock`);
}
function sockAlive(sid) { return IS_WIN || fs.existsSync(sockPath(sid)); }

// ── Agent 历史（本地读取） ────────────────────────────────────────────────────
function loadProjects(agent = 'claude') {
  return normalizeAgent(agent) === 'codex' ? loadCodexProjects() : loadClaudeProjects();
}

function loadClaudeProjects() {
  if (!fs.existsSync(CLAUDE_DIR)) return [];
  const dirs = fs.readdirSync(CLAUDE_DIR, { withFileTypes: true })
    .filter(d => d.isDirectory()).map(d => d.name);
  const result = [];
  for (const dir of dirs) {
    const sessions = loadClaudeSessions(dir);
    if (!sessions.length) continue;
    result.push({ id: dir, displayPath: sessions[0].cwd || dir, sessions });
  }
  return result.sort((a, b) =>
    new Date(b.sessions[0].lastModified) - new Date(a.sessions[0].lastModified));
}

function loadCodexProjects() {
  const sessions = loadCodexSessions();
  if (!sessions.length) return [];

  const byProject = new Map();
  for (const session of sessions) {
    const current = byProject.get(session.projectId) || {
      id: session.projectId,
      displayPath: session.cwd || '~',
      sessions: [],
    };
    current.sessions.push(session);
    byProject.set(session.projectId, current);
  }

  return Array.from(byProject.values()).sort((a, b) =>
    new Date(b.sessions[0]?.lastModified || 0) - new Date(a.sessions[0]?.lastModified || 0));
}

function loadCodexSessions() {
  const byId = loadCodexSessionsFromFiles();
  for (const item of loadCodexHistoryEntries()) {
    const id = item.session_id;
    const lastModified = item.ts ? new Date(item.ts * 1000).toISOString() : '';
    const current = byId.get(id) || {
      sessionId: id,
      cwd: '',
      lastMessage: '',
      messageCount: 0,
      lastModified: new Date(0).toISOString(),
    };
    current.historyCount = (current.historyCount || 0) + 1;
    if (item.text) current.lastMessage = String(item.text).slice(0, 80);
    if (lastModified && new Date(lastModified) > new Date(current.lastModified)) current.lastModified = lastModified;
    byId.set(id, current);
  }

  return Array.from(byId.values())
    .map(normalizeCodexSession)
    .sort((a, b) => new Date(b.lastModified) - new Date(a.lastModified));
}

function loadCodexHistoryEntries() {
  if (!fs.existsSync(CODEX_HISTORY_FILE)) return [];
  try {
    return fs.readFileSync(CODEX_HISTORY_FILE, 'utf8')
      .trim()
      .split('\n')
      .filter(Boolean)
      .map(line => { try { return JSON.parse(line); } catch (_) { return null; } })
      .filter(item => item?.session_id);
  } catch (_) {
    return [];
  }
}

function loadCodexSessionsFromFiles() {
  const byId = new Map();
  for (const filePath of listCodexSessionFiles()) {
    const session = readCodexSessionFile(filePath);
    if (session?.sessionId) byId.set(session.sessionId, session);
  }
  return byId;
}

function listCodexSessionFiles() {
  if (!fs.existsSync(CODEX_SESSIONS_DIR)) return [];
  const files = [];
  const stack = [CODEX_SESSIONS_DIR];
  while (stack.length) {
    const dir = stack.pop();
    let entries = [];
    try { entries = fs.readdirSync(dir, { withFileTypes: true }); } catch (_) { continue; }
    for (const entry of entries) {
      const fullPath = path.join(dir, entry.name);
      if (entry.isDirectory()) stack.push(fullPath);
      else if (entry.isFile() && entry.name.endsWith('.jsonl')) files.push(fullPath);
    }
  }
  return files;
}

function readCodexSessionFile(filePath) {
  let stat;
  try { stat = fs.statSync(filePath); } catch (_) { return null; }
  const session = {
    sessionId: '',
    cwd: '',
    lastMessage: '',
    messageCount: 0,
    lastModified: stat.mtime.toISOString(),
  };

  let content = '';
  try { content = fs.readFileSync(filePath, 'utf8'); } catch (_) { return null; }
  for (const line of content.split('\n')) {
    if (!line.trim()) continue;
    let obj;
    try { obj = JSON.parse(line); } catch (_) { continue; }

    if (obj.timestamp && new Date(obj.timestamp) > new Date(session.lastModified)) {
      session.lastModified = new Date(obj.timestamp).toISOString();
    }

    if (obj.type === 'session_meta' && obj.payload) {
      if (!session.sessionId && obj.payload.id) session.sessionId = obj.payload.id;
      if (!session.cwd && obj.payload.cwd) session.cwd = obj.payload.cwd;
      if (obj.payload.timestamp && new Date(obj.payload.timestamp) > new Date(session.lastModified)) {
        session.lastModified = new Date(obj.payload.timestamp).toISOString();
      }
    }

    if (obj.type === 'turn_context' && obj.payload?.cwd && !session.cwd) {
      session.cwd = obj.payload.cwd;
    }

    if (obj.type === 'response_item' && obj.payload?.type === 'message') {
      const role = obj.payload.role;
      if (role === 'user' || role === 'assistant') session.messageCount += 1;
      if (role === 'user') {
        const text = extractCodexMessageText(obj.payload.content);
        if (text && !isEnvironmentContext(text)) session.lastMessage = text.slice(0, 80);
      }
    }
  }

  return session;
}

function extractCodexMessageText(content) {
  if (typeof content === 'string') return content;
  if (!Array.isArray(content)) return '';
  const textPart = content.find(part => part && (part.type === 'input_text' || part.type === 'output_text' || part.type === 'text'));
  return textPart?.text || '';
}

function isEnvironmentContext(text) {
  return String(text).trim().startsWith('<environment_context>');
}

function normalizeCodexSession(session) {
  const cwd = session.cwd || '~';
  return {
    sessionId: session.sessionId,
    cwd,
    projectId: codexProjectId(cwd),
    lastMessage: session.lastMessage || '',
    messageCount: session.messageCount || session.historyCount || 0,
    lastModified: session.lastModified || new Date(0).toISOString(),
  };
}

function codexProjectId(cwd) {
  const hash = crypto.createHash('sha1').update(cwd || '~').digest('hex').slice(0, 16);
  return `codex-${hash}`;
}

function loadClaudeSessions(projectId) {
  const dir = path.join(CLAUDE_DIR, projectId);
  if (!fs.existsSync(dir)) return [];
  return fs.readdirSync(dir)
    .filter(f => f.endsWith('.jsonl'))
    .map(f => {
      const fp   = path.join(dir, f);
      const stat = fs.statSync(fp);
      const prev = parseJSONL(fp);
      return { sessionId: f.replace('.jsonl', ''), cwd: prev.cwd,
               lastMessage: prev.lastMessage, messageCount: prev.messageCount,
               lastModified: stat.mtime.toISOString() };
    })
    .sort((a, b) => new Date(b.lastModified) - new Date(a.lastModified));
}

function parseJSONL(fp) {
  let cwd = '', lastMessage = '', messageCount = 0;
  try {
    const lines = fs.readFileSync(fp, 'utf8').trim().split('\n').filter(Boolean);
    for (const line of lines) {
      try {
        const obj = JSON.parse(line);
        if (obj.cwd && !cwd) cwd = obj.cwd;
        if (obj.type === 'user' || obj.type === 'assistant') {
          messageCount++;
          if (obj.type === 'user') {
            const c = obj.message?.content;
            if (typeof c === 'string') lastMessage = c.slice(0, 80);
            else if (Array.isArray(c)) {
              const t = c.find(p => p.type === 'text');
              if (t) lastMessage = t.text.slice(0, 80);
            }
          }
        }
      } catch (_) {}
    }
  } catch (_) {}
  return { cwd, lastMessage, messageCount };
}

function fmtDate(iso) {
  if (!iso) return '';
  const d = new Date(iso);
  const diff = Date.now() - d.getTime();
  if (diff < 86400000) return d.toLocaleTimeString('zh-CN', { hour: '2-digit', minute: '2-digit' });
  return d.toLocaleDateString('zh-CN', { month: '2-digit', day: '2-digit' });
}

// ── WS 创建会话 ───────────────────────────────────────────────────────────────
function wsMask(text) {
  const payload = Buffer.from(text, 'utf8');
  const mask    = crypto.randomBytes(4);
  let hLen = 6;
  if (payload.length > 125 && payload.length <= 65535) hLen = 8;
  else if (payload.length > 65535) hLen = 14;
  const frame = Buffer.alloc(hLen + payload.length);
  frame[0] = 0x81;
  if (payload.length < 126) { frame[1] = 0x80 | payload.length; mask.copy(frame, 2); }
  else if (payload.length <= 65535) { frame[1] = 0xfe; frame.writeUInt16BE(payload.length, 2); mask.copy(frame, 4); }
  else { frame[1] = 0xff; frame.writeBigUInt64BE(BigInt(payload.length), 2); mask.copy(frame, 10); }
  for (let i = 0; i < payload.length; i++) frame[hLen + i] = payload[i] ^ mask[i % 4];
  return frame;
}

function parseWsFrames(buf, onText) {
  const b = Buffer.isBuffer(buf) ? buf : Buffer.from(buf, 'binary');
  let i = 0;
  while (i + 2 <= b.length) {
    const fin = (b[i] & 0x80) !== 0, op = b[i] & 0x0f;
    let len = b[i+1] & 0x7f, off = i + 2;
    if (len === 126) { if (off+2 > b.length) break; len = b.readUInt16BE(off); off += 2; }
    else if (len === 127) { if (off+8 > b.length) break; len = Number(b.readBigUInt64BE(off)); off += 8; }
    if (off + len > b.length) break;
    if (op === 1 && fin) onText(b.slice(off, off+len).toString('utf8'));
    i = off + len;
  }
}

function wsCreate(host, port, token, workingDir, name, resumeSessionId, agent) {
  return new Promise((resolve, reject) => {
    const key = crypto.randomBytes(16).toString('base64');
    const sock = net.createConnection(port, host);
    let upgraded = false, binBuf = Buffer.alloc(0), sessionId = null;
    const timer = setTimeout(() => { sock.destroy(); reject(new Error('超时')); }, 15000);

    sock.on('connect', () => {
      sock.write(
        `GET /ws?token=${encodeURIComponent(token)} HTTP/1.1\r\n` +
        `Host: ${host}:${port}\r\n` +
        `Upgrade: websocket\r\nConnection: Upgrade\r\n` +
        `Sec-WebSocket-Key: ${key}\r\nSec-WebSocket-Version: 13\r\n\r\n`
      );
    });
    sock.on('data', chunk => {
      if (!upgraded) {
        const s = chunk.toString('binary'), idx = s.indexOf('\r\n\r\n');
        if (idx === -1) return;
        if (!s.includes('101')) { sock.destroy(); reject(new Error('WS 握手失败')); return; }
        upgraded = true;
        const rest = chunk.slice(Buffer.from(s.slice(0, idx + 4), 'binary').length);
        if (rest.length) binBuf = Buffer.concat([binBuf, rest]);
      } else {
        binBuf = Buffer.concat([binBuf, chunk]);
      }
      if (!upgraded) return;
      parseWsFrames(binBuf, text => {
        try {
          const msg = JSON.parse(text);
          if (msg.type === 'session_list') {
            const payload = {
              type: 'start', workingDir, name, agent: normalizeAgent(agent),
              cols: process.stdout.columns || 80,
              rows: process.stdout.rows    || 24,
              // 透传当前 shell 的全部环境变量，确保用户的 PATH/conda/pyenv 等生效
              env: process.env,
            };
            if (resumeSessionId) payload.resumeSessionId = resumeSessionId;
            sock.write(wsMask(JSON.stringify(payload)));
          } else if (msg.type === 'session_id') {
            sessionId = msg.sessionId; clearTimeout(timer); sock.destroy(); resolve(sessionId);
          } else if (msg.type === 'error') {
            clearTimeout(timer); sock.destroy(); reject(new Error(msg.message));
          }
        } catch (_) {}
      });
    });
    sock.on('error', e => { clearTimeout(timer); reject(e); });
    sock.on('close', () => { if (!sessionId) { clearTimeout(timer); reject(new Error('连接断开')); } });
  });
}

// ── 接入 socket ───────────────────────────────────────────────────────────────
// 逃逸键：Ctrl+] (ASCII 29, \x1d) — 历史上 telnet 的断开键
// 在 socket 层拦截，不传给 PTY，触发断开回菜单
const ESCAPE_KEY = '\x1d';

function doAttach(sp, sname, onDetach, sessionId) {
  wr(A.show + '\n' + A.cyan + '  已接入 ' + A.b + sname + A.R +
     A.gray + '  （Ctrl+] 断开回菜单，不终止会话）\n\n' + A.R);

  const sock = net.createConnection(sp);

  // 清除 stdin 残留监听器
  process.stdin.removeAllListeners('data');
  process.stdin.removeAllListeners('keypress');
  if (process.stdin.isTTY) process.stdin.setRawMode(true);
  process.stdin.resume();

  const sendResize = () => {
    const cols = process.stdout.columns || 80;
    const rows = process.stdout.rows    || 24;
    if (!sock.destroyed) try { sock.write(`\x00RESIZE:${cols}:${rows}\n`); } catch (_) {}
  };

  const onStdinData = (chunk) => {
    const bytes = Buffer.isBuffer(chunk) ? chunk : Buffer.from(chunk);
    for (let i = 0; i < bytes.length; i++) {
      if (bytes[i] === 0x1d) { detach(true); return; }
    }
    if (!sock.destroyed) try { sock.write(bytes); } catch (_) {}
  };

  let resizeRetry = null;
  const onSockData = (chunk) => { process.stdout.write(chunk); };

  sock.on('connect', () => {
    sendResize();
    resizeRetry = setTimeout(sendResize, 300);
    process.stdout.on('resize', sendResize);
    process.stdin.on('data', onStdinData);
    sock.on('data', onSockData);
  });

  // 防重入：error 和 close 都会触发，只处理一次
  let detached = false;
  const detach = (fromEscape) => {
    if (detached) return;
    detached = true;

    process.stdin.removeAllListeners('data');
    sock.removeAllListeners();
    process.stdout.removeListener('resize', sendResize);
    clearInterval(watchdog);
    if (resizeRetry) { clearTimeout(resizeRetry); resizeRetry = null; }
    if (!sock.destroyed) try { sock.destroy(); } catch (_) {}

    if (process.stdin.isTTY) try { process.stdin.setRawMode(false); } catch (_) {}
    // 不调 resume()，让 stdin 保持 paused 状态
    // menu() 会通过 setRawMode(true) 重新激活它
    process.stdout.write('\x1b[?1049l\x1b[?25h\x1b[0m\r\n');

    const msg = fromEscape
      ? A.cyan + '[已断开]' + A.R
      : A.green + '[会话已结束]' + A.R;
    wr(msg + '\n');

    // CC 退出时等 6s（服务端 5s 后清理 session），确保 meta 文件已更新
    const delay = fromEscape ? 300 : 6000;
    setTimeout(() => {
      process.stdin.removeAllListeners('data');
      process.stdin.removeAllListeners('keypress');
      // pause 确保不在 flowing 模式，menu() 的 setRawMode+on(keypress) 能正常工作
      process.stdin.pause();
      onDetach();
    }, delay);
  };

  // 服务掉线监测
  const watchdog = setInterval(() => {
    if (!serverAlive(serverInfo())) {
      detached = true;
      clearInterval(watchdog);
      process.stdin.removeAllListeners('data');
      sock.removeAllListeners();
      if (!sock.destroyed) try { sock.destroy(); } catch (_) {}
      process.stdout.removeListener('resize', sendResize);
      if (process.stdin.isTTY) try { process.stdin.setRawMode(false); } catch (_) {}
      process.stdout.write('\x1b[?1049l\x1b[?25h\x1b[0m\r\n');
      wr(A.red + '[服务已停止，ahub-tui 退出]' + A.R + '\n');
      process.exit(0);
    }
  }, 3000);

  sock.on('error', () => detach(false));
  sock.on('close', () => detach(false));
}

function returnToMainAfterDetach() {
  // doAttach removes readline's internal data listeners; re-register before menu().
  readline.emitKeypressEvents(process.stdin);
  pageMain().catch(err => {
    wr(A.show + '\n' + A.red + '  错误: ' + err.message + A.R + '\n');
    process.exit(1);
  });
}

// ── 通用菜单 ──────────────────────────────────────────────────────────────────
// items: [{ label, sub?, hint?, _sep?, _disabled? }]
// 返回 index（number）或 null（q/Esc）
// 全局只需调用一次，防止叠加内部 data 监听器
readline.emitKeypressEvents(process.stdin);
// 防止 Node.js MaxListeners 警告（menu/attach 会动态添加监听器）
process.stdin.setMaxListeners(50);
process.stdout.setMaxListeners(50);

function menu(title, items, opts = {}) {
  const { hdr = '', footer = '', banner = false } = opts;
  return new Promise(resolve => {
    let cur = items.findIndex(i => !i._sep && !i._disabled);
    if (cur < 0) cur = 0;

    const render = () => {
      wr(A.clear + A.hide);
      wr('\n');
      if (banner) {
        // 大字 banner（主菜单专用）
        wr(A.b + A.cyan);
        wr('   █████╗ ██╗  ██╗██╗   ██╗██████╗ \n');
        wr('  ██╔══██╗██║  ██║██║   ██║██╔══██╗\n');
        wr('  ███████║███████║██║   ██║██████╔╝\n');
        wr('  ██╔══██║██╔══██║██║   ██║██╔══██╗\n');
        wr('  ██║  ██║██║  ██║╚██████╔╝██████╔╝\n');
        wr('  ╚═╝  ╚═╝╚═╝  ╚═╝ ╚═════╝ ╚═════╝\n');
        wr(A.R + '  ' + A.d + 'AgentHub' + A.R + '\n');
      } else {
        wr(ctr(A.b + A.cyan + '[ AgentHub ]' + A.R) + '\n');
      }
      if (hdr) wr(ctr(hdr) + '\n');
      wr('\n' + hr() + '\n');
      wr(' ' + A.b + title + A.R + '\n');
      wr(hr('·', A.d) + '\n\n');

      items.forEach((item, i) => {
        if (item._sep) { wr('  ' + A.d + '·'.repeat(Math.min(36, W()-4)) + A.R + '\n'); return; }
        const sel = i === cur;
        const pre = sel ? A.BG + A.white + ' › ' : '   ';
        const suf = sel ? A.R : '';
        wr(pre + (item._disabled ? A.d : '') + item.label + suf);
        if (item.hint && sel) wr('  ' + A.gray + item.hint + A.R);
        wr('\n');
        if (item.sub && sel) wr('       ' + A.gray + item.sub + A.R + '\n');
      });

      wr('\n' + hr('·', A.d) + '\n');
      if (footer) wr(A.gray + '  ' + footer + A.R + '\n');
      wr(A.gray + '  ↑↓ 选择   Enter 确认   q/Esc 返回   Ctrl+C 退出' + A.R + '\n');
    };

    const next = (dir) => {
      let i = cur;
      for (let n = 0; n < items.length; n++) {
        i = (i + dir + items.length) % items.length;
        if (!items[i]._sep && !items[i]._disabled) return i;
      }
      return cur;
    };

    const done = (v) => {
      process.stdin.removeListener('keypress', onKey);
      // 不再重复调用 emitKeypressEvents，避免叠加内部 data 监听器
      if (process.stdin.isTTY) try { process.stdin.setRawMode(false); } catch (_) {}
      // 不调 resume()，保持 paused 状态，下一个 menu() 调用会通过 setRawMode 激活
      wr(A.show);
      resolve(v);
    };

    const onKey = (_, k) => {
      if (!k) return;
      if (k.name === 'up'   || (k.ctrl && k.name === 'p')) { cur = next(-1); render(); }
      else if (k.name === 'down' || (k.ctrl && k.name === 'n')) { cur = next(+1); render(); }
      else if (k.name === 'return' || k.name === 'enter') done(cur);
      else if (k.name === 'escape' || k.name === 'q')    done(null);
      else if (k.ctrl && k.name === 'c') { done(null); wr('\n'); process.exit(0); }
    };

    // 确保没有残留的 keypress 监听器
    process.stdin.removeAllListeners('keypress');
    if (process.stdin.isTTY) process.stdin.setRawMode(true);
    process.stdin.on('keypress', onKey);
    render();
  });
}

// ── 输入框 ────────────────────────────────────────────────────────────────────
function input(question, def = '') {
  return new Promise(resolve => {
    wr(A.show);
    if (process.stdin.isTTY) process.stdin.setRawMode(false);
    process.stdin.resume();
    const rl = readline.createInterface({ input: process.stdin, output: process.stdout, terminal: false });
    rl.question('  ' + A.cyan + question + A.R + (def ? A.gray + ` [${def}]` + A.R : '') + ': ',
      ans => {
        rl.close();
        // 关闭 readline 后 stdin 可能被 pause，恢复它供下次菜单使用
        process.stdin.resume();
        resolve(ans.trim() || def);
      });
  });
}

// ── 通知行 ────────────────────────────────────────────────────────────────────
async function notice(msg, color = A.green, delay = 1000) {
  wr(A.show + '\n  ' + color + msg + A.R + '\n');
  await sl(delay);
}

// ── 确认框 ────────────────────────────────────────────────────────────────────
async function confirm(msg) {
  return new Promise(resolve => {
    wr(A.show + '\n  ' + A.yellow + msg + A.R + A.gray + '  (y/N): ' + A.R);
    if (process.stdin.isTTY) process.stdin.setRawMode(false);
    process.stdin.resume();
    const rl = readline.createInterface({ input: process.stdin, output: process.stdout, terminal: false });
    rl.once('line', ans => { rl.close(); process.stdin.resume(); resolve(ans.trim().toLowerCase() === 'y'); });
  });
}

